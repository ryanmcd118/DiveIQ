# Database
# SQLite (development): file:./prisma/dev.db
# PostgreSQL (production): postgresql://user:password@host:5432/database
DATABASE_URL="file:./prisma/dev.db"

# NextAuth Configuration
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here-min-32-chars"
# Base URL of your application (used for OAuth callbacks)
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXTAUTH_URL="http://localhost:3000"

# Google OAuth (Optional - only required if using Google sign-in)
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# OpenAI API (Required for AI dive plan features)
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY="sk-your-openai-api-key"

# UploadThing (Optional - only required if using avatar uploads)
# Get from: https://uploadthing.com/dashboard
UPLOADTHING_TOKEN="your-uploadthing-token"
